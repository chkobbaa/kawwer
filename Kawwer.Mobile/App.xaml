<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:kawwer"
             xmlns:conv="clr-namespace:Kawwer.Mobile.Converters"
             x:Class="kawwer.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:InvertedBoolConverter x:Key="InvertedBool" />
            <conv:StringNotEmptyConverter x:Key="StringNotEmpty" />
            <conv:IntGreaterThanZeroConverter x:Key="IntGreaterThanZero" />
            <conv:NotNullConverter x:Key="NotNull" />
            <conv:IntAtLeastConverter x:Key="IntAtLeast" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
