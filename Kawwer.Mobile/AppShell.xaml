<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="kawwer.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Kawwer.Mobile.Views"
    Title="Kawwer"
    FlyoutBehavior="Disabled">

    <ShellContent
        Route="login"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Shell.NavBarIsVisible="False" />

    <!-- Full-screen first-run onboarding flow (no tabs, no nav bar). -->
    <ShellContent
        Route="onboarding"
        ContentTemplate="{DataTemplate views:OnboardingPage}"
        Shell.NavBarIsVisible="False" />

    <!-- Icon-only bottom navigation (labels are hidden by KawwerShellRenderer); Home sits in the middle. -->
    <TabBar Route="main">
        <Tab Title="Discover" Route="discovertab" Icon="tab_discover.png">
            <ShellContent ContentTemplate="{DataTemplate views:DiscoverPage}" Route="discover" />
        </Tab>
        <Tab Title="Calendar" Route="calendartab" Icon="tab_calendar.png">
            <ShellContent ContentTemplate="{DataTemplate views:CalendarPage}" Route="calendar" />
        </Tab>
        <Tab Title="Home" Route="hometab" Icon="tab_home.png">
            <ShellContent ContentTemplate="{DataTemplate views:HomePage}" Route="home" />
        </Tab>
        <Tab Title="Friends" Route="friendstab" Icon="tab_friends.png">
            <ShellContent ContentTemplate="{DataTemplate views:FriendsPage}" Route="friends" />
        </Tab>
        <Tab Title="Profile" Route="profiletab" Icon="tab_profile.png">
            <ShellContent ContentTemplate="{DataTemplate views:ProfilePage}" Route="profile" />
        </Tab>
    </TabBar>

</Shell>
