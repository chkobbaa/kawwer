<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Kawwer.Mobile.Views.IncomingCallPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Ink}">
    <Grid RowDefinitions="*,Auto,*,Auto" Padding="28,64,28,56">

        <VerticalStackLayout Grid.Row="1" Spacing="18" HorizontalOptions="Center">
            <Label Text="Kawwer · Incoming update" FontSize="13" CharacterSpacing="2"
                   TextColor="{StaticResource Volt}" HorizontalOptions="Center" />
            <Border x:Name="Pulse" WidthRequest="120" HeightRequest="120" StrokeThickness="0"
                    BackgroundColor="{StaticResource InkSoft}" HorizontalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="60" />
                </Border.StrokeShape>
                <Label Text="📣" FontSize="52" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            <Label x:Name="CallerLabel" FontSize="26" FontAttributes="Bold" TextColor="White"
                   HorizontalTextAlignment="Center" HorizontalOptions="Center" />
            <Label x:Name="DetailLabel" FontSize="15" TextColor="#9DB5A5"
                   HorizontalTextAlignment="Center" HorizontalOptions="Center" />
        </VerticalStackLayout>

        <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="20" VerticalOptions="End">
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                <Border WidthRequest="66" HeightRequest="66" StrokeThickness="0" BackgroundColor="{StaticResource Error}"
                        HorizontalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="33" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDismiss" />
                    </Border.GestureRecognizers>
                    <Label Text="✕" FontSize="26" FontAttributes="Bold" TextColor="White"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Label Text="Dismiss" FontSize="12" TextColor="#9DB5A5" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" Spacing="8" HorizontalOptions="Center">
                <Border WidthRequest="66" HeightRequest="66" StrokeThickness="0" BackgroundColor="{StaticResource Volt}"
                        HorizontalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="33" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnView" />
                    </Border.GestureRecognizers>
                    <Label Text="View" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource Ink}"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Label Text="Open" FontSize="12" TextColor="#9DB5A5" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
