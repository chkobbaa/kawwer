<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Kawwer.Mobile.Views.LoginPage"
             Title="Kawwer"
             BackgroundColor="{StaticResource BackgroundLight}">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16" VerticalOptions="Center">
            <Label Text="⚽ Kawwer" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource Primary}" />
            <Label Text="Organize football matches with your friends" HorizontalOptions="Center" TextColor="{StaticResource Gray500}" />

            <Border Stroke="{StaticResource Gray200}" StrokeThickness="1" Padding="20" Margin="0,16,0,0"
                    StrokeShape="RoundRectangle 16" BackgroundColor="{StaticResource SurfaceLight}">
                <VerticalStackLayout Spacing="12">
                    <Entry Placeholder="Username or email" Text="{Binding UsernameOrEmail}" Keyboard="Email" />
                    <Entry Placeholder="Password" Text="{Binding Password}" IsPassword="True" />

                    <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmpty}}" />

                    <Button Text="Sign in" Command="{Binding LoginCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBool}}"
                            BackgroundColor="{StaticResource Primary}" TextColor="White" />
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
                    <Button Text="Create an account" Command="{Binding GoToRegisterCommand}"
                            BackgroundColor="Transparent" TextColor="{StaticResource Secondary}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
