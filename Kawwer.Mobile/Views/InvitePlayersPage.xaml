<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Kawwer.Mobile.Controls"
             x:Class="Kawwer.Mobile.Views.InvitePlayersPage"
             x:Name="PageRoot"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}">
    <Grid RowDefinitions="Auto,*,Auto" Padding="16,8,16,16" RowSpacing="10">

        <VerticalStackLayout Spacing="10">
            <Label Text="{Binding Hint}" Style="{StaticResource StatCaption}" Margin="4,0" />
            <Border Style="{StaticResource ErrorBanner}"
                    IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmpty}}">
                <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}" FontSize="13" />
            </Border>

            <!-- Guest players: people without the app, added by name. -->
            <Label Text="GUEST PLAYERS" Style="{StaticResource SectionTitle}" Margin="4,4,0,0" />
            <Border Style="{StaticResource StatTile}" Padding="12">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Add someone who doesn't have the app. They'll appear in the roster and on the lineup board."
                           Style="{StaticResource StatCaption}" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Border Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="12,0">
                            <Entry Placeholder="Guest name (e.g. John Doe)" Text="{Binding GuestName}"
                                   Style="{StaticResource FormEntry}" ReturnCommand="{Binding AddGuestCommand}" />
                        </Border>
                        <Button Grid.Column="1" Text="Add" Style="{StaticResource PrimaryButton}"
                                HeightRequest="46" Padding="18,0" FontSize="14"
                                Command="{Binding AddGuestCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBool}}" />
                    </Grid>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Guests}" Spacing="6" IsVisible="{Binding HasGuests}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                                    <Border Style="{StaticResource Avatar}" WidthRequest="34" HeightRequest="34"
                                            StrokeShape="RoundRectangle 17"
                                            BackgroundColor="{AppThemeBinding Light=#FFF3E0, Dark=#3D2E1A}">
                                        <Label Style="{StaticResource AvatarLabel}" FontSize="13" Text="{Binding Initial}"
                                               TextColor="{StaticResource Warning}" />
                                    </Border>
                                    <Label Grid.Column="1" Text="{Binding Name}" FontSize="15" FontAttributes="Bold"
                                           VerticalOptions="Center" LineBreakMode="TailTruncation" />
                                    <Border Grid.Column="2" Style="{StaticResource Pill}" VerticalOptions="Center"
                                            BackgroundColor="{AppThemeBinding Light=#FFF3E0, Dark=#3D2E1A}">
                                        <Label Style="{StaticResource PillLabel}" Text="GUEST" TextColor="{StaticResource Warning}" />
                                    </Border>
                                    <Button Grid.Column="3" Text="✕" FontSize="14" WidthRequest="34" HeightRequest="34" Padding="0"
                                            BackgroundColor="Transparent" TextColor="{StaticResource Error}" VerticalOptions="Center"
                                            Command="{Binding BindingContext.RemoveGuestCommand, Source={x:Reference PageRoot}}"
                                            CommandParameter="{Binding .}" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Label Text="INVITE FRIENDS" Style="{StaticResource SectionTitle}" Margin="4,4,0,0" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Friends}" SelectionMode="None">
            <CollectionView.EmptyView>
                <controls:EmptyStateView Illustration="empty_friends.png" IllustrationSize="120"
                                         Title="No one to invite"
                                         Message="All of your friends are already part of this match, or you have no friends to invite yet." />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,3" Style="{StaticResource StatTile}" Padding="8,4">
                        <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
                            <CheckBox IsChecked="{Binding IsSelected}" VerticalOptions="Center" />
                            <controls:AvatarView Grid.Column="1" Size="34" ImageUrl="{Binding User.ProfilePictureUrl}" Initials="{Binding User.Initials}" />
                            <Label Grid.Column="2" Text="{Binding User.FullName}" FontSize="15" VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <VerticalStackLayout Grid.Row="2" Spacing="6">
            <Button Text="{Binding SendButtonText}" Style="{StaticResource PrimaryButton}"
                    Command="{Binding SendCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBool}}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
