<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Kawwer.Mobile.Views.NotificationsPage"
             x:Name="PageRoot"
             Title="Notifications"
             BackgroundColor="{StaticResource BackgroundLight}">
    <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding LoadCommand}">
        <CollectionView ItemsSource="{Binding Notifications}" EmptyView="You're all caught up.">
            <CollectionView.Header>
                <Button Text="Mark all read" Command="{Binding MarkAllReadCommand}" Margin="16,12"
                        BackgroundColor="{StaticResource Secondary}" TextColor="White" />
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="16,4" Padding="12" StrokeShape="RoundRectangle 12"
                            BackgroundColor="{StaticResource SurfaceLight}" Stroke="{StaticResource Gray200}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding BindingContext.MarkReadCommand, Source={x:Reference PageRoot}}"
                                CommandParameter="{Binding Id}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding Title}" FontAttributes="Bold" />
                            <Label Text="{Binding Message}" TextColor="{StaticResource Gray600}" />
                            <Label Text="{Binding CreatedAt, StringFormat='{0:dd MMM HH:mm}'}" FontSize="10" TextColor="{StaticResource Gray400}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </RefreshView>
</ContentPage>
