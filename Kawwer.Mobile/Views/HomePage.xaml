<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Kawwer.Mobile.Views.HomePage"
             x:Name="PageRoot"
             Title="Home"
             BackgroundColor="{StaticResource BackgroundLight}">
    <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding LoadCommand}">
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="16">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="{Binding Greeting}" FontSize="24" FontAttributes="Bold" VerticalOptions="Center" />
                    <Button Grid.Column="1" Text="🔔" Command="{Binding OpenNotificationsCommand}"
                            BackgroundColor="Transparent" FontSize="20" />
                </Grid>

                <Button Text="➕ Create match" Command="{Binding CreateMatchCommand}"
                        BackgroundColor="{StaticResource Primary}" TextColor="White" />

                <Label Text="Your upcoming matches" FontSize="18" FontAttributes="Bold" />
                <CollectionView ItemsSource="{Binding Upcoming}" EmptyView="No upcoming matches yet.">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,4" Padding="14" StrokeShape="RoundRectangle 16"
                                    BackgroundColor="{StaticResource SurfaceLight}" Stroke="{StaticResource Gray200}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding BindingContext.OpenMatchCommand, Source={x:Reference PageRoot}}"
                                        CommandParameter="{Binding Id}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="16" />
                                    <Label Text="{Binding WhenLabel}" TextColor="{StaticResource Gray500}" />
                                    <Label Text="{Binding Field.Name}" TextColor="{StaticResource Gray500}" />
                                    <Label Text="{Binding PlayersLabel}" TextColor="{StaticResource Primary}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Matches you organize" FontSize="18" FontAttributes="Bold" />
                <CollectionView ItemsSource="{Binding Dashboard}" EmptyView="You haven't organized any matches.">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,4" Padding="14" StrokeShape="RoundRectangle 16"
                                    BackgroundColor="{StaticResource SurfaceLight}" Stroke="{StaticResource Gray200}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding BindingContext.OpenMatchCommand, Source={x:Reference PageRoot}}"
                                        CommandParameter="{Binding MatchId}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="16" />
                                    <Label Text="{Binding FieldName}" TextColor="{StaticResource Gray500}" />
                                    <Label TextColor="{StaticResource Secondary}">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0} accepted · {1} waiting · {2} TND to collect">
                                                <Binding Path="AcceptedCount" />
                                                <Binding Path="WaitingCount" />
                                                <Binding Path="MoneyRemaining" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
