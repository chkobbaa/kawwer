<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Kawwer.Mobile.Controls"
             x:Class="Kawwer.Mobile.Views.ChatPage"
             Title="Match chat"
             BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}">
    <Grid RowDefinitions="*,Auto">
        <CollectionView Grid.Row="0" ItemsSource="{Binding Messages}" Margin="12,8" ItemsUpdatingScrollMode="KeepLastItemInView">
            <CollectionView.EmptyView>
                <controls:EmptyStateView Illustration="empty_chat.png"
                                         Title="No messages yet"
                                         Message="Say hi, confirm the plan, or hype the squad." />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="4,3">
                        <!-- Bubble: theirs left, mine right, system centered -->
                        <Border MaximumWidthRequest="300" HorizontalOptions="Start" StrokeThickness="0"
                                StrokeShape="RoundRectangle 16,16,4,16" Padding="12,8"
                                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsMine}" Value="True">
                                    <Setter Property="HorizontalOptions" Value="End" />
                                    <Setter Property="BackgroundColor" Value="{StaticResource Ink}" />
                                    <Setter Property="StrokeShape" Value="RoundRectangle 16,16,16,4" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSystem}" Value="True">
                                    <Setter Property="HorizontalOptions" Value="Center" />
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource TintGreen}, Dark={StaticResource TintGreenDark}}" />
                                    <Setter Property="StrokeShape" Value="RoundRectangle 14" />
                                </DataTrigger>
                            </Border.Triggers>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding SenderName}" FontSize="11" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                       IsVisible="{Binding IsMine, Converter={StaticResource InvertedBool}}" />
                                <Label Text="{Binding Content}" FontSize="15">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsMine}" Value="True">
                                            <Setter Property="TextColor" Value="White" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsSystem}" Value="True">
                                            <Setter Property="FontSize" Value="12" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                                <Label Text="{Binding CreatedAt, StringFormat='{0:HH:mm}'}" FontSize="10"
                                       TextColor="{StaticResource Gray400}" HorizontalOptions="End">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsMine}" Value="True">
                                            <Setter Property="TextColor" Value="#7E9A88" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Composer -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Padding="12,8" ColumnSpacing="8"
              BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">
            <Border Style="{StaticResource InputBorder}">
                <Entry Style="{StaticResource FormEntry}" Placeholder="Type a message"
                       Text="{Binding Draft}" ReturnCommand="{Binding SendCommand}" ReturnType="Send" />
            </Border>
            <Border Grid.Column="1" BackgroundColor="{StaticResource Ink}" StrokeThickness="0"
                    StrokeShape="RoundRectangle 24" WidthRequest="48" HeightRequest="48"
                    SemanticProperties.Description="Send message">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SendCommand}" />
                </Border.GestureRecognizers>
                <Path Style="{StaticResource Icon}" Data="{StaticResource IconSend}" WidthRequest="18" HeightRequest="18"
                      Fill="{StaticResource Volt}" HorizontalOptions="Center" VerticalOptions="Center" Margin="2,0,0,0" />
            </Border>
        </Grid>
    </Grid>
</ContentPage>
