<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Kawwer.Mobile.Views.DiscoverPage"
             x:Name="PageRoot"
             Title="Discover"
             BackgroundColor="{StaticResource BackgroundLight}">
    <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding LoadCommand}">
        <CollectionView ItemsSource="{Binding Matches}" EmptyView="No public matches nearby. Pull to refresh.">
            <CollectionView.Header>
                <Label Text="Public matches near you" FontSize="20" FontAttributes="Bold" Padding="16,16,16,0" />
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="16,8" Padding="14" StrokeShape="RoundRectangle 16"
                            BackgroundColor="{StaticResource SurfaceLight}" Stroke="{StaticResource Gray200}">
                        <Grid ColumnDefinitions="*,Auto" RowSpacing="4">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="16" />
                                <Label Text="{Binding WhenLabel}" TextColor="{StaticResource Gray500}" />
                                <Label Text="{Binding DistanceLabel}" TextColor="{StaticResource Gray500}" />
                                <Label Text="{Binding AvailableSpots, StringFormat='{0} spots left'}" TextColor="{StaticResource Primary}" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1" Text="Join" VerticalOptions="Center"
                                    Command="{Binding BindingContext.JoinCommand, Source={x:Reference PageRoot}}"
                                    CommandParameter="{Binding Id}"
                                    BackgroundColor="{StaticResource Primary}" TextColor="White" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </RefreshView>
</ContentPage>
