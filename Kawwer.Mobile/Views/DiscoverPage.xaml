<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Kawwer.Mobile.Controls"
             x:Class="Kawwer.Mobile.Views.DiscoverPage"
             x:Name="PageRoot"
             Title="Discover"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}">
    <!-- Fixed header outside the scrolling area so the title lines up with the other tabs
         and never slides under the status bar. -->
    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Padding="16,12,16,4" Spacing="6">
            <Label Text="Discover" Style="{StaticResource ScreenTitle}" />
            <Label Text="Public matches around you" FontSize="14" TextColor="{StaticResource Gray500}" />
            <Border Style="{StaticResource ErrorBanner}"
                    IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmpty}}">
                <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}" FontSize="13" />
            </Border>
        </VerticalStackLayout>
        <RefreshView Grid.Row="1" IsRefreshing="{Binding IsRefreshing}" Command="{Binding LoadCommand}">
        <CollectionView ItemsSource="{Binding Matches}">
            <CollectionView.EmptyView>
                <Grid>
                    <controls:ListSkeletonView IsVisible="{Binding ShowSkeleton}" />
                    <controls:EmptyStateView Illustration="empty_discover.png"
                                             Title="Nothing nearby right now"
                                             Message="Pull to refresh, or create a public match and let players find you."
                                             IsVisible="{Binding ShowSkeleton, Converter={StaticResource InvertedBool}}" />
                </Grid>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="16,5" Style="{StaticResource StatTile}" Padding="14">
                        <Border.GestureRecognizers>
                            <!-- Tapping anywhere on the card (except the Join button) opens the full match details. -->
                            <TapGestureRecognizer
                                Command="{Binding BindingContext.OpenMatchCommand, Source={x:Reference PageRoot}}"
                                CommandParameter="{Binding Id}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="10">
                            <!-- Organizer row -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <controls:AvatarView Size="36" ImageUrl="{Binding Organizer.ProfilePictureUrl}" Initials="{Binding Organizer.Initials}" />
                                <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                    <Label Text="{Binding Organizer.FullName}" FontSize="13" FontAttributes="Bold" />
                                    <Label Text="Organizer" FontSize="11" TextColor="{StaticResource Gray500}" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="{Binding WhenLabel}" FontSize="12"
                                       TextColor="{StaticResource Gray500}" VerticalOptions="Center" />
                            </Grid>

                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="17" />
                                <Label Text="{Binding DistanceLabel}" FontSize="13" TextColor="{StaticResource Gray500}" />
                            </VerticalStackLayout>

                            <!-- Capacity + join -->
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                                <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                                    <ProgressBar Progress="{Binding FillRatio}" />
                                    <Label Text="{Binding AvailableSpots, StringFormat='{0} spots left'}" FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />
                                </VerticalStackLayout>
                                <Button Grid.Column="1" Text="Join" FontAttributes="Bold" CornerRadius="20"
                                        HeightRequest="40" Padding="20,0"
                                        BackgroundColor="{StaticResource Ink}" TextColor="{StaticResource Volt}"
                                        Command="{Binding BindingContext.JoinCommand, Source={x:Reference PageRoot}}"
                                        CommandParameter="{Binding Id}">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsJoined}" Value="True">
                                            <Setter Property="Text" Value="Already In" />
                                            <Setter Property="IsEnabled" Value="False" />
                                            <Setter Property="Opacity" Value="0.5" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
