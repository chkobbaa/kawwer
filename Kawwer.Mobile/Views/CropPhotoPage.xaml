<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Kawwer.Mobile.Views.CropPhotoPage"
             Title="Adjust photo"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Ink}">
    <Grid RowDefinitions="Auto,*,Auto" Padding="20,24">

        <VerticalStackLayout Spacing="4">
            <Label Text="Position your photo" FontSize="20" FontAttributes="Bold" TextColor="White"
                   HorizontalOptions="Center" />
            <Label Text="Pinch to zoom · drag to reposition" FontSize="13" TextColor="#9DB5A5"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Square viewport (clipped by the Border) holding the pannable/zoomable image plus a
             circular mask overlay that previews exactly what will be cropped. -->
        <Border Grid.Row="1" x:Name="Viewport" WidthRequest="300" HeightRequest="300"
                StrokeThickness="0" HorizontalOptions="Center" VerticalOptions="Center">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16" />
            </Border.StrokeShape>
            <Border.GestureRecognizers>
                <PinchGestureRecognizer PinchUpdated="OnPinchUpdated" />
                <PanGestureRecognizer PanUpdated="OnPanUpdated" />
            </Border.GestureRecognizers>
            <Grid BackgroundColor="{StaticResource InkSoft}">
                <Image x:Name="PreviewImage" Aspect="AspectFit" WidthRequest="300" HeightRequest="300" />
                <GraphicsView x:Name="MaskCanvas" InputTransparent="True" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="12">
            <Button Text="Cancel" Style="{StaticResource OutlineButton}"
                    BorderColor="{StaticResource Volt}" TextColor="{StaticResource Volt}"
                    Clicked="OnCancelClicked" />
            <Button Grid.Column="1" Text="Use photo" Style="{StaticResource PrimaryButton}"
                    BackgroundColor="{StaticResource Volt}" TextColor="{StaticResource Ink}"
                    Clicked="OnUseClicked" />
        </Grid>
    </Grid>
</ContentPage>
