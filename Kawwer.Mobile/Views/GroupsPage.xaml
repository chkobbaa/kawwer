<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Kawwer.Mobile.Views.GroupsPage"
             x:Name="PageRoot"
             Title="Groups"
             BackgroundColor="{StaticResource BackgroundLight}">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">
            <Label Text="Your groups" FontSize="24" FontAttributes="Bold" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry Placeholder="New group name" Text="{Binding NewGroupName}" />
                <Button Grid.Column="1" Text="Create" Command="{Binding CreateCommand}"
                        BackgroundColor="{StaticResource Primary}" TextColor="White" />
            </Grid>

            <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmpty}}" />

            <CollectionView ItemsSource="{Binding Groups}" EmptyView="No groups yet.">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,4" Padding="12" StrokeShape="RoundRectangle 12"
                                BackgroundColor="{StaticResource SurfaceLight}" Stroke="{StaticResource Gray200}">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout>
                                    <Label Text="{Binding Name}" FontAttributes="Bold" />
                                    <Label Text="{Binding MemberCount, StringFormat='{0} members'}" TextColor="{StaticResource Gray500}" />
                                </VerticalStackLayout>
                                <Button Grid.Column="1" Text="Delete"
                                        Command="{Binding BindingContext.DeleteCommand, Source={x:Reference PageRoot}}"
                                        CommandParameter="{Binding Id}"
                                        BackgroundColor="{StaticResource Error}" TextColor="White" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
