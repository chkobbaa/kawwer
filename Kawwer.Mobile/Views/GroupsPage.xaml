<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Kawwer.Mobile.Views.GroupsPage"
             x:Name="PageRoot"
             Title="Groups"
             BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}">
    <ScrollView>
        <VerticalStackLayout Padding="16,12,16,24" Spacing="10">
            <VerticalStackLayout Spacing="2">
                <Label Text="Groups" Style="{StaticResource ScreenTitle}" />
                <Label Text="Invite a whole crew in one tap" FontSize="14" TextColor="{StaticResource Gray500}" />
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Border Style="{StaticResource InputBorder}">
                    <Entry Style="{StaticResource FormEntry}" Placeholder="New group name" Text="{Binding NewGroupName}" />
                </Border>
                <Button Grid.Column="1" Text="Create" FontAttributes="Bold" CornerRadius="14"
                        HeightRequest="48" Padding="18,0"
                        BackgroundColor="{StaticResource Ink}" TextColor="{StaticResource Volt}"
                        Command="{Binding CreateCommand}" />
            </Grid>

            <Border Style="{StaticResource ErrorBanner}"
                    IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmpty}}">
                <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}" FontSize="13" />
            </Border>

            <CollectionView ItemsSource="{Binding Groups}">
                <CollectionView.EmptyView>
                    <Border Style="{StaticResource StatTile}" Padding="20,24">
                        <VerticalStackLayout Spacing="10">
                            <Border Style="{StaticResource EmptyIconBubble}">
                                <Path Style="{StaticResource Icon}" Data="{StaticResource IconGroup}" WidthRequest="24" HeightRequest="24"
                                      Fill="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                      HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Text="No groups yet" Style="{StaticResource EmptyTitle}" />
                            <Label Text="Create a group like 'Thursday Crew' to invite everyone at once."
                                   Style="{StaticResource EmptyBody}" />
                        </VerticalStackLayout>
                    </Border>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,4" Style="{StaticResource StatTile}" Padding="12">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Border Style="{StaticResource Avatar}">
                                    <Path Style="{StaticResource Icon}" Data="{StaticResource IconGroup}" WidthRequest="18" HeightRequest="18"
                                          Fill="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                          HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                                    <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="15" />
                                    <Label Text="{Binding MemberCount, StringFormat='{0} members'}" FontSize="12"
                                           TextColor="{StaticResource Gray500}" />
                                </VerticalStackLayout>
                                <Border Grid.Column="2" Style="{StaticResource IconBubble}" WidthRequest="36" HeightRequest="36"
                                        BackgroundColor="{AppThemeBinding Light=#FDECEA, Dark=#3B1F1E}" VerticalOptions="Center"
                                        SemanticProperties.Description="Delete group">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding BindingContext.DeleteCommand, Source={x:Reference PageRoot}}"
                                            CommandParameter="{Binding Id}" />
                                    </Border.GestureRecognizers>
                                    <Path Style="{StaticResource Icon}" Data="{StaticResource IconClose}" WidthRequest="15" HeightRequest="15"
                                          Fill="{StaticResource Error}" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
