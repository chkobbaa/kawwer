<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Kawwer.Mobile.Views.RegisterPage"
             Title="Create account"
             BackgroundColor="{StaticResource BackgroundLight}">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="12">
            <Label Text="Create your account" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Primary}" />

            <Entry Placeholder="First name" Text="{Binding FirstName}" />
            <Entry Placeholder="Last name" Text="{Binding LastName}" />
            <Entry Placeholder="Username" Text="{Binding Username}" />
            <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email" />
            <Entry Placeholder="Phone number (optional)" Text="{Binding PhoneNumber}" Keyboard="Telephone" />
            <Entry Placeholder="Password" Text="{Binding Password}" IsPassword="True" />
            <Entry Placeholder="Confirm password" Text="{Binding ConfirmPassword}" IsPassword="True" />

            <Label Text="Password needs 8+ chars with upper, lower and a number." FontSize="12" TextColor="{StaticResource Gray500}" />
            <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmpty}}" />

            <Button Text="Register" Command="{Binding RegisterCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBool}}"
                    BackgroundColor="{StaticResource Primary}" TextColor="White" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            <Button Text="Back to sign in" Command="{Binding BackToLoginCommand}"
                    BackgroundColor="Transparent" TextColor="{StaticResource Secondary}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
