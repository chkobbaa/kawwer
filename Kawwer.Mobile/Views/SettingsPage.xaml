<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Kawwer.Mobile.Controls"
             x:Class="Kawwer.Mobile.Views.SettingsPage"
             Title="Settings"
             BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}">
    <ScrollView>
        <VerticalStackLayout Padding="16,8,16,24" Spacing="10">

            <Label Text="PROFILE" Style="{StaticResource SectionTitle}" />

            <!-- Tappable avatar: pick and upload a new profile photo -->
            <VerticalStackLayout Spacing="6" HorizontalOptions="Center" Margin="0,4,0,8">
                <controls:AvatarView Size="96" Initials="{Binding Initials}" ImageUrl="{Binding ProfilePictureUrl}"
                                     SemanticProperties.Description="Change profile photo">
                    <controls:AvatarView.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PickPhotoCommand}" />
                    </controls:AvatarView.GestureRecognizers>
                </controls:AvatarView>
                <Label Text="Change photo" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PickPhotoCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </VerticalStackLayout>

            <!-- Field labels above every entry (placeholders alone aren't enough). -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Label Text="First name" Style="{StaticResource SectionTitle}" />
                <Label Grid.Column="1" Text="Last name" Style="{StaticResource SectionTitle}" />
            </Grid>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Border Style="{StaticResource InputBorder}">
                    <Entry Style="{StaticResource FormEntry}" Placeholder="First name" Text="{Binding FirstName}" />
                </Border>
                <Border Grid.Column="1" Style="{StaticResource InputBorder}">
                    <Entry Style="{StaticResource FormEntry}" Placeholder="Last name" Text="{Binding LastName}" />
                </Border>
            </Grid>

            <Label Text="Phone number" Style="{StaticResource SectionTitle}" />
            <Border Style="{StaticResource InputBorder}">
                <Entry Style="{StaticResource FormEntry}" Placeholder="Phone number" Keyboard="Telephone" Text="{Binding PhoneNumber}" />
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Label Text="Preferred position" Style="{StaticResource SectionTitle}" />
                <Label Grid.Column="1" Text="Preferred foot" Style="{StaticResource SectionTitle}" />
            </Grid>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Border Style="{StaticResource InputBorder}">
                    <Picker Title="Preferred position" ItemsSource="{Binding PositionOptions}" SelectedItem="{Binding SelectedPosition}" />
                </Border>
                <Border Grid.Column="1" Style="{StaticResource InputBorder}">
                    <Picker Title="Preferred foot" ItemsSource="{Binding FootOptions}" SelectedItem="{Binding SelectedFoot}" />
                </Border>
            </Grid>

            <Label Text="PRIVACY" Style="{StaticResource SectionTitle}" />
            <Label Text="Profile visibility" Style="{StaticResource SectionTitle}" />
            <Border Style="{StaticResource InputBorder}">
                <Picker Title="Profile visibility" ItemsSource="{Binding VisibilityOptions}" SelectedItem="{Binding SelectedVisibility}" />
            </Border>

            <Border Style="{StaticResource ErrorBanner}"
                    IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmpty}}">
                <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}" FontSize="13" />
            </Border>

            <Button Text="Save changes" Style="{StaticResource PrimaryButton}" HeightRequest="48"
                    Command="{Binding SaveProfileCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBool}}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

            <Label Text="NOTIFICATIONS" Style="{StaticResource SectionTitle}" />
            <Border Style="{StaticResource StatTile}" Padding="14,4">
                <VerticalStackLayout>
                    <Grid ColumnDefinitions="*,Auto" HeightRequest="52">
                        <VerticalStackLayout Spacing="0" VerticalOptions="Center">
                            <Label Text="Match updates" FontSize="15" />
                            <Label Text="Invitations, changes and reminders" Style="{StaticResource StatCaption}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" IsToggled="{Binding NotifyMatches}" VerticalOptions="Center" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" HeightRequest="52">
                        <VerticalStackLayout Spacing="0" VerticalOptions="Center">
                            <Label Text="Payments" FontSize="15" />
                            <Label Text="Collection started and reminders" Style="{StaticResource StatCaption}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" IsToggled="{Binding NotifyPayments}" VerticalOptions="Center" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" HeightRequest="52">
                        <VerticalStackLayout Spacing="0" VerticalOptions="Center">
                            <Label Text="Friends and teams" FontSize="15" />
                            <Label Text="Requests and team activity" Style="{StaticResource StatCaption}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" IsToggled="{Binding NotifyFriends}" VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Label Text="ABOUT" Style="{StaticResource SectionTitle}" />
            <Border Style="{StaticResource StatTile}" Padding="4">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Padding="10,8">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CheckForUpdatesCommand}" />
                    </Grid.GestureRecognizers>
                    <Path Style="{StaticResource Icon}" Data="{StaticResource IconCog}"
                          Fill="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                          VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="Check for updates" FontSize="15" VerticalOptions="Center" />
                    <Path Grid.Column="2" Style="{StaticResource Icon}" Data="{StaticResource IconChevronRight}"
                          Fill="{StaticResource Gray300}" VerticalOptions="Center" />
                </Grid>
            </Border>

            <Label Text="ACCOUNT" Style="{StaticResource SectionTitle}" />
            <Border Style="{StaticResource StatTile}" Padding="4">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Padding="10,8">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                    </Grid.GestureRecognizers>
                    <Path Style="{StaticResource Icon}" Data="{StaticResource IconLogout}" Fill="{StaticResource Error}"
                          VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="Log out" FontSize="15" TextColor="{StaticResource Error}" VerticalOptions="Center" />
                    <Path Grid.Column="2" Style="{StaticResource Icon}" Data="{StaticResource IconChevronRight}"
                          Fill="{StaticResource Gray300}" VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Destructive: deactivate the account for good. -->
            <Button Text="Delete account" Style="{StaticResource DangerOutlineButton}" HeightRequest="48" Margin="0,4,0,0"
                    Command="{Binding DeleteAccountCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBool}}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
