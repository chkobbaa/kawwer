<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Kawwer.Mobile.Views.FriendsPage"
             x:Name="PageRoot"
             Title="Friends"
             BackgroundColor="{StaticResource BackgroundLight}">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="Friends" FontSize="24" FontAttributes="Bold" VerticalOptions="Center" />
                <Button Grid.Column="1" Text="Groups" Command="{Binding OpenGroupsCommand}"
                        BackgroundColor="{StaticResource Secondary}" TextColor="White" />
            </Grid>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry Placeholder="Search players by name" Text="{Binding SearchTerm}" />
                <Button Grid.Column="1" Text="Search" Command="{Binding SearchCommand}"
                        BackgroundColor="{StaticResource Primary}" TextColor="White" />
            </Grid>

            <CollectionView ItemsSource="{Binding SearchResults}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*,Auto" Padding="8">
                            <Label Text="{Binding FullName}" VerticalOptions="Center" />
                            <Button Grid.Column="1" Text="Add"
                                    Command="{Binding BindingContext.SendRequestCommand, Source={x:Reference PageRoot}}"
                                    CommandParameter="{Binding Id}"
                                    BackgroundColor="{StaticResource Primary}" TextColor="White" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Requests" FontSize="18" FontAttributes="Bold" />
            <CollectionView ItemsSource="{Binding Requests}" EmptyView="No pending requests.">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*,Auto,Auto" Padding="8" ColumnSpacing="6">
                            <Label Text="{Binding User.FullName}" VerticalOptions="Center" />
                            <Button Grid.Column="1" Text="✓"
                                    IsVisible="{Binding IsIncoming}"
                                    Command="{Binding BindingContext.AcceptCommand, Source={x:Reference PageRoot}}"
                                    CommandParameter="{Binding FriendshipId}"
                                    BackgroundColor="{StaticResource Success}" TextColor="White" />
                            <Button Grid.Column="2" Text="✕"
                                    Command="{Binding BindingContext.RejectCommand, Source={x:Reference PageRoot}}"
                                    CommandParameter="{Binding FriendshipId}"
                                    BackgroundColor="{StaticResource Error}" TextColor="White" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Your friends" FontSize="18" FontAttributes="Bold" />
            <CollectionView ItemsSource="{Binding Friends}" EmptyView="No friends yet. Search to add some!">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,4" Padding="12" StrokeShape="RoundRectangle 12"
                                BackgroundColor="{StaticResource SurfaceLight}" Stroke="{StaticResource Gray200}">
                            <Label Text="{Binding User.FullName}" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
