<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="Kawwer.Mobile.Views.SuccessPopup"
               CanBeDismissedByTappingOutsideOfPopup="True">
    <Border Padding="18,14" StrokeThickness="0" StrokeShape="RoundRectangle 20"
            BackgroundColor="{StaticResource Ink}" HorizontalOptions="Center" VerticalOptions="Center">
        <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
            <Border WidthRequest="34" HeightRequest="34" StrokeThickness="0" StrokeShape="RoundRectangle 17"
                    BackgroundColor="{StaticResource Volt}" VerticalOptions="Center">
                <Path Style="{StaticResource Icon}" Data="{StaticResource IconCheck}" WidthRequest="18" HeightRequest="18"
                      Fill="{StaticResource Ink}" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            <Label x:Name="MessageLabel" FontSize="14" FontAttributes="Bold" TextColor="White"
                   VerticalOptions="Center" MaximumWidthRequest="240" />
        </HorizontalStackLayout>
    </Border>
</toolkit:Popup>
