<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Kawwer.Mobile.Controls.EmptyStateView">
    <VerticalStackLayout Padding="24,32" Spacing="12">
        <Image x:Name="IllustrationImage"
               HeightRequest="150"
               WidthRequest="150"
               HorizontalOptions="Center" />
        <Label x:Name="TitleLabel" Style="{StaticResource EmptyTitle}" />
        <Label x:Name="MessageLabel" Style="{StaticResource EmptyBody}" />
    </VerticalStackLayout>
</ContentView>
